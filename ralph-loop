#!/usr/bin/env bash
set -euo pipefail

cleanup() { kill 0 2>/dev/null; wait 2>/dev/null; }
trap cleanup EXIT INT TERM

while :; do
  ready=$(bd ready --json 2>/dev/null || echo "[]")
  if [ "$ready" = "[]" ] || [ -z "$ready" ]; then
    echo "No ready work. Sleeping 60s..."
    sleep 60
    continue
  fi

  opencode run --model github-copilot/gpt-5.3-codex "follow @PROMPT.md"
done
